# ============================================================
#  SmartReview Backend — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit the actual .env file to git.
# ============================================================

# ── SERVER ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=info

# ── DATABASE (PostgreSQL) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartreview
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ── REDIS ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT AUTH ──────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=changeme_generate_a_real_256bit_secret
JWT_EXPIRES=7d

# ── RAZORPAY (get from razorpay.com dashboard) ───────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ── TWILIO WHATSAPP (get from twilio.com console) ────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886

# ── EMAIL (SMTP — use Gmail App Password, not your real password) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=SmartReview <youraddress@gmail.com>

# ── CLOUDINARY (optional — for menu item photo uploads) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS — comma-separated list of allowed frontend origins ──
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
